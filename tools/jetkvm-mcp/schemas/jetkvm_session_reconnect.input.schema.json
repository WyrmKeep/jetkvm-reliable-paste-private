{
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "session_generation": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "request_id": {
      "$ref": "#/properties/session_id"
    },
    "takeover": {
      "type": "boolean",
      "default": false
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    }
  },
  "required": [
    "session_id",
    "session_generation",
    "request_id",
    "timeout_ms"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
