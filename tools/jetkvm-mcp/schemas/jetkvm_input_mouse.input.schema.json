{
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "session_generation": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "observation_id": {
      "$ref": "#/properties/session_id"
    },
    "request_id": {
      "$ref": "#/properties/session_id"
    },
    "actions": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "move"
              },
              "x": {
                "$ref": "#/properties/session_generation"
              },
              "y": {
                "$ref": "#/properties/session_generation"
              }
            },
            "required": [
              "type",
              "x",
              "y"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "click"
              },
              "x": {
                "$ref": "#/properties/session_generation"
              },
              "y": {
                "$ref": "#/properties/session_generation"
              },
              "button": {
                "type": "string",
                "enum": [
                  "left",
                  "middle",
                  "right"
                ]
              }
            },
            "required": [
              "type",
              "x",
              "y",
              "button"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "double_click"
              },
              "x": {
                "$ref": "#/properties/session_generation"
              },
              "y": {
                "$ref": "#/properties/session_generation"
              },
              "button": {
                "$ref": "#/properties/actions/items/anyOf/1/properties/button"
              }
            },
            "required": [
              "type",
              "x",
              "y",
              "button"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "drag"
              },
              "button": {
                "$ref": "#/properties/actions/items/anyOf/1/properties/button"
              },
              "path": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "$ref": "#/properties/session_generation"
                    },
                    "y": {
                      "$ref": "#/properties/session_generation"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "minItems": 2,
                "maxItems": 64
              }
            },
            "required": [
              "type",
              "button",
              "path"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "scroll"
              },
              "x": {
                "$ref": "#/properties/session_generation"
              },
              "y": {
                "$ref": "#/properties/session_generation"
              },
              "delta_y": {
                "type": "integer",
                "minimum": -127,
                "maximum": 127,
                "not": {
                  "const": 0
                }
              },
              "delta_x": {
                "type": "number",
                "const": 0
              }
            },
            "required": [
              "type",
              "x",
              "y",
              "delta_y"
            ],
            "additionalProperties": false
          }
        ]
      },
      "minItems": 1,
      "maxItems": 16
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    }
  },
  "required": [
    "session_id",
    "session_generation",
    "observation_id",
    "request_id",
    "actions",
    "timeout_ms"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
