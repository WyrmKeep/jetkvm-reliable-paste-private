  "environments": ["fake", "replay", "live"],
  "preconditions": [
    {
      "id": "outer-device-lease",
      "description": "The harness holds the inherited device-keyed lease before any device or fixture access.",
      "required": true
    },
    {
      "id": "safe-baseline",
      "description": "The harness recorded session generation, display, layout, lock state, ATX-observable state, browser identity, and fixture identity.",
      "required": true
    },
    {
      "id": "scenario-ready",
      "description": "The request ledger is empty and the release operation can return a definitive generation-drained result.",
      "required": true
    },
    {
      "id": "matrix-tool-fixtures",
      "description": "The harness serially retires each completed ledger case, provisions the next tool in a unique current session generation, and captures a tool-unique fresh observation before every input case that consumes one.",
      "required": true
    }
  ],
  "fault_script": [
    {
      "id": "repeat-ledger-key",
      "after_step": "initial-release",
      "boundary": "before_admission",
      "action": "Within each explicitly prepared tool case, repeat the exact tool-scoped request and digest, then reuse the same request identifier with changed normalized input before retiring that case.",
      "expected_effect": "The exact duplicate returns cached definitive evidence with zero write; changed input returns REQUEST_ID_REUSED_WITH_DIFFERENT_INPUT with zero write; no closed generation or consumed observation reaches the next tool."
    }
  ],
