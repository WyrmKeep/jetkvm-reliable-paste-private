      "input": {
        "session_id": "opaque-session",
        "session_generation": 7,
        "request_id": "opaque-request",
        "timeout_ms": 1000
      },
      "timeout_ms": 1000,
      "expect": "A definitive applied generation-drained result is stored."
    },
