{
  "id": "duplicate-request-id-definitive-replay",
  "title": "Duplicate request identifiers replay only definitive results",
  "requirements": [
    "branch:duplicate-same-request-digest",
    "branch:duplicate-changed-digest"
  ],
  "tools": [
    "jetkvm_input_keyboard",
    "jetkvm_input_mouse",
    "jetkvm_input_paste",
    "jetkvm_input_release",
    "jetkvm_power_control",
    "jetkvm_session_connect",
    "jetkvm_session_reconnect"
  ],
  "environments": ["fake", "replay", "live"],
  "preconditions": [
    {
      "id": "outer-device-lease",
      "description": "The harness holds the inherited device-keyed lease before any device or fixture access.",
      "required": true
    },
    {
      "id": "safe-baseline",
      "description": "The harness recorded session generation, display, layout, lock state, ATX-observable state, browser identity, and fixture identity.",
      "required": true
    },
    {
      "id": "scenario-ready",
      "description": "The request ledger is empty and the release operation can return a definitive generation-drained result.",
      "required": true
    },
    {
      "id": "matrix-tool-fixtures",
      "description": "The harness provisions each linked tool call with its valid owned session, required capability, and a separately captured fresh observation when the handler consumes one.",
      "required": true
    }
  ],
  "fault_script": [
    {
      "id": "repeat-ledger-key",
      "after_step": "initial-release",
      "boundary": "before_admission",
      "action": "For every mutation tool, repeat the exact tool-scoped request and digest, then reuse the same request identifier with changed normalized input.",
      "expected_effect": "The exact duplicate returns cached definitive evidence with zero write; changed input returns REQUEST_ID_REUSED_WITH_DIFFERENT_INPUT with zero write."
    }
  ],
