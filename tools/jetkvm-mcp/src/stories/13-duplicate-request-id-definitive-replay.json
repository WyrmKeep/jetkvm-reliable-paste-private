  "title": "Duplicate request identifiers replay only definitive results",
  "requirements": [
    "branch:duplicate-same-request-digest",
    "branch:duplicate-changed-digest"
  ],
  "tools": [
    "jetkvm_input_keyboard",
    "jetkvm_input_mouse",
    "jetkvm_input_paste",
    "jetkvm_input_release",
    "jetkvm_power_control",
    "jetkvm_session_connect",
    "jetkvm_session_reconnect"
