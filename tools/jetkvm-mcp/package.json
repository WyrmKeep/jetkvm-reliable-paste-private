{
  "name": "@wyrmkeep/jetkvm-mcp",
  "version": "0.1.0",
  "description": "Computer-use MCP server for JetKVM",
  "license": "GPL-2.0-only",
  "type": "module",
  "engines": {
    "node": ">=22.23.1 <23"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run && node --test scripts/*.test.mjs",
    "test:task1": "vitest run src/domain.test.ts src/errors.test.ts src/runtimePolicy.test.ts src/deviceLease.test.ts src/deviceLeaseRunner.test.ts",
    "test:device-go-runner": "node --test scripts/run-device-go-tests.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.build.json",
    "device-lease:run": "node dist/deviceLeaseRunner.js",
    "test:installed-lease": "npm run build && node scripts/installed-device-lease-smoke.mjs",
    "package:check": "npm run build && node scripts/check-package.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "playwright-core": "1.57.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "playwright": "1.57.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
